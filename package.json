{
  "name": "smwdle",
  "version": "0.1.0",
  "private": true,
  "description": "Smwdle — daily Summoners War monster guessing game (Classic mode).",
  "scripts": {
    "dev": "next dev -p 1011",
    "build": "next build",
    "start": "next start -p 1011",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "format": "prettier --write .",
    "fetch:monsters": "tsx scripts/fetch-monsters.ts"
  },
  "dependencies": {
    "next": "14.2.5",
    "next-intl": "^3.17.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "fast-check": "^3.19.0",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.39",
    "prettier": "^3.3.2",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
